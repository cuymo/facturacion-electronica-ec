{
  "name": "@facturacion-ec/core",
  "private": true,
  "version": "0.1.0-beta.1",
  "description": "Core types, XML builders, clave de acceso, catalogs and validation for SRI Ecuador electronic invoicing",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist"],
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "sri",
    "ecuador",
    "factura",
    "facturacion-electronica",
    "comprobantes-electronicos",
    "xml",
    "clave-acceso",
    "iva"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/cuymo/facturacion-electronica-ec.git",
    "directory": "packages/core"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "test": "vitest run"
  },
  "devDependencies": {
    "rimraf": "^6.0.0",
    "tsup": "^8.4.0",
    "typescript": "~5.7.0",
    "vitest": "^3.0.0"
  }
}
