{
  "name": "facturacion-electronica-ec",
  "version": "1.0.1",
  "description": "Libreria TypeScript para emision de comprobantes electronicos del SRI Ecuador. Soporta factura, liquidacion de compra, nota de credito, nota de debito, guia de remision y comprobante de retencion.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist", "xsd", "README.md"],
  "engines": {
    "node": ">=24.18.0"
  },
  "keywords": [
    "sri",
    "ecuador",
    "factura",
    "facturacion-electronica",
    "comprobantes-electronicos",
    "nota-credito",
    "nota-debito",
    "retencion",
    "guia-remision",
    "liquidacion-compra",
    "xades",
    "xml",
    "firma-electronica",
    "clave-acceso"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cuymo/facturacion-electronica-ec.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/cuymo/facturacion-electronica-ec#readme",
  "bugs": {
    "url": "https://github.com/cuymo/facturacion-electronica-ec/issues"
  },
  "scripts": {
    "build": "tsup && node -e \"const{cpSync,mkdirSync}=require('fs');mkdirSync('./xsd',{recursive:true});cpSync('../../vendor/sri/xsd','./xsd',{recursive:true,filter:(s)=>s.endsWith('.xsd')||!s.includes('.')});cpSync('../../README.md','./README.md')\"",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "fast-xml-parser": "^5.9.3"
  },
  "peerDependencies": {
    "ec-sri-invoice-signer": ">=1.6.0 <2.0.0",
    "xmllint-wasm": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "xmllint-wasm": {
      "optional": true
    }
  },
  "devDependencies": {
    "@facturacion-ec/core": "workspace:*",
    "@facturacion-ec/signer": "workspace:*",
    "@facturacion-ec/sri-client": "workspace:*",
    "ec-sri-invoice-signer": "^1.7.5",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "~6.0.3",
    "vitest": "^4.1.9"
  }
}
