{
  "name": "@facturacion-ec/signer",
  "private": true,
  "version": "1.0.0",
  "description": "XAdES-BES signing adapter for SRI Ecuador electronic documents",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist"],
  "engines": {
    "node": ">=24.18.0"
  },
  "keywords": [
    "sri",
    "ecuador",
    "xades",
    "firma-electronica",
    "p12",
    "xml-signature"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/cuymo/facturacion-electronica-ec.git",
    "directory": "packages/signer"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@facturacion-ec/core": "workspace:*"
  },
  "peerDependencies": {
    "ec-sri-invoice-signer": ">=1.6.0 <2.0.0"
  },
  "devDependencies": {
    "ec-sri-invoice-signer": "^1.7.5",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "~6.0.3",
    "vitest": "^4.1.9"
  }
}
