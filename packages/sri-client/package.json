{
  "name": "@facturacion-ec/sri-client",
  "private": true,
  "version": "1.0.0",
  "description": "SOAP client for SRI Ecuador reception and authorization web services",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist"],
  "engines": {
    "node": ">=24.18.0"
  },
  "keywords": [
    "sri",
    "ecuador",
    "soap",
    "comprobantes-electronicos",
    "autorizacion",
    "recepcion"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/cuymo/facturacion-electronica-ec.git",
    "directory": "packages/sri-client"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@facturacion-ec/core": "workspace:*",
    "fast-xml-parser": "^5.9.3"
  },
  "devDependencies": {
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "~6.0.3",
    "vitest": "^4.1.9"
  }
}
