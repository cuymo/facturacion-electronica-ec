# ============================================================
# FacturaYa Integration Test Configuration
# ============================================================
# Copy this file to .env.test and fill in the values.
# NEVER commit .env.test to version control.
#
# These variables are ONLY used when running integration tests
# with FACTURAYA_TEST_RUN_INTEGRATION=true.
# Without that flag, all integration tests are skipped.
# ============================================================

# --- Required for integration tests ---

# Path to a .p12 certificate file issued by the SRI for testing.
# Must be associated with the RUC below.
FACTURAYA_TEST_P12_PATH=./your_test_certificate.p12

# Password for the .p12 file above.
FACTURAYA_TEST_P12_PASSWORD=""

# 13-digit RUC associated with the test certificate.
FACTURAYA_TEST_RUC=

# --- Safety flags ---

# Set to "true" to enable integration tests against SRI PRUEBAS.
# Default: unset (integration tests are skipped).
FACTURAYA_TEST_RUN_INTEGRATION=false


# HARDCODED TO '1' (PRUEBAS). The integration test scaffold
# rejects any attempt to use ambiente '2' (PRODUCCION).
# This variable exists for documentation only; it cannot be
# changed to '2' without modifying the safeguard code.
FACTURAYA_TEST_AMBIENTE=1
